  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.77.0",
    "@earendil-works/pi-tui": "0.77.0",
    "@types/node": "^24.10.1",
    "typebox": "1.1.38",
    "typescript": "^5.9.3"
  }
}
